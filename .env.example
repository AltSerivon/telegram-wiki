# Copy to `.env` and fill in (or edit the generated `.env` in the repo root).

# Telegram — https://my.telegram.org → API development tools
# Replace with YOUR App api_id (number) and api_hash (string):
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

TELEGRAM_SESSION_PATH=./data/telegram.session

# Obsidian — full path to the folder you open as a vault (no API key needed)
OBSIDIAN_VAULT_PATH=/path/to/your/vault

DATABASE_URL=sqlite:///./data/app.db

OPENAI_API_KEY=
OPENAI_BASE_URL=
WIKI_MODEL=gpt-4o-mini

# Output: $OBSIDIAN_VAULT_PATH/_telegram_wiki/<slug>/
