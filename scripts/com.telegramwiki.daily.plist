<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.telegramwiki.daily</string>
  <key>RunAtLoad</key>
  <false/>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>6</integer>
    <key>Minute</key>
    <integer>15</integer>
  </dict>
  <key>WorkingDirectory</key>
  <string>/path/to/telegram-info</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
  </dict>
  <key>ProgramArguments</key>
  <array>
    <string>/path/to/telegram-info/.venv/bin/telegram-wiki</string>
    <string>run-daily</string>
  </array>
  <key>StandardOutPath</key>
  <string>/path/to/telegram-info/data/launchd-telegram-wiki.log</string>
  <key>StandardErrorPath</key>
  <string>/path/to/telegram-info/data/launchd-telegram-wiki.err</string>
</dict>
</plist>
